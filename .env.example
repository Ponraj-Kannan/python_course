# Optional: override Zoho data-centre domain
# https://accounts.zoho.com      (default, US)
# https://accounts.zoho.eu       (Europe)
# https://accounts.zoho.in       (India)
# https://accounts.zoho.com.au   (Australia)
ZOHO_ACCOUNTS_DOMAIN=https://accounts.zoho.com
VITE_ZOHO_ACCOUNTS_DOMAIN=https://accounts.zoho.com

