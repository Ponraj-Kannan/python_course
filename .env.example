# ─────────────────────────────────────────────────────────────────────────────
# Zoho OAuth2 Configuration
# Register your app at https://api-console.zoho.com/
# Product: Zoho Accounts  |  Type: Server-based Applications
# Scopes: openid profile email
# ─────────────────────────────────────────────────────────────────────────────

# ── Server-side only (Vercel serverless / Node backend) ──────────────────────
ZOHO_CLIENT_ID=1000.0MEP244JVHCKQTBUBOIMNR4QH6MKEF
ZOHO_CLIENT_SECRET=c7986a30162aa67f0715af73345c3acd25caae8617

# ── Frontend (VITE_ prefix = bundled into the browser, public) ──────────────
# Must be the same Client ID as above — safe to expose (client secrets are NOT)
VITE_ZOHO_CLIENT_ID=1000.0MEP244JVHCKQTBUBOIMNR4QH6MKEF

# Optional: override Zoho data-centre domain
# https://accounts.zoho.com      (default, US)
# https://accounts.zoho.eu       (Europe)
# https://accounts.zoho.in       (India)
# https://accounts.zoho.com.au   (Australia)
ZOHO_ACCOUNTS_DOMAIN=https://accounts.zoho.com
VITE_ZOHO_ACCOUNTS_DOMAIN=https://accounts.zoho.com

# ─────────────────────────────────────────────────────────────────────────────
# Code Execution API (existing)
# ─────────────────────────────────────────────────────────────────────────────
# VITE_EXECUTION_API_URL=http://136.111.214.182:3000
# VITE_EXECUTION_API_KEY=your_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# Welcome Email — Zoho Mail API
# Follow ZOHO_MAIL_SETUP.md to generate these values.
# Scope required: ZohoMail.messages.CREATE
# ─────────────────────────────────────────────────────────────────────────────

# Long-lived OAuth2 refresh token with ZohoMail.messages.CREATE scope
ZOHO_MAIL_REFRESH_TOKEN=1000.70b3c5c6ab04dd877b7eaaec66556c9d.a02c55798bcb75934339241c2762b209

# Numeric account ID — retrieve once via: GET https://mail.zoho.in/api/accounts
ZOHO_MAIL_ACCOUNT_ID=5069617000000002002

# Sender address (must be a verified address in your Zoho Mail account)
ZOHO_MAIL_FROM_ADDRESS=ponraj.kannan@faceprep.in
ZOHO_MAIL_FROM_NAME=FACEPrep Team

# Public URL of the course slide deck
PROJECT_URL=https://python-course-woad.vercel.app/1
